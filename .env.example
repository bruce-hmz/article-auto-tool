# ============================================
# LLM Configuration (文章生成模型配置)
# ============================================

# 选择 LLM 提供商: claude | openai | deepseek | zhipu | moonshot | ollama | custom
LLM_PROVIDER=deepseek

# 模型名称 (可选，不填则使用默认模型)
# Claude: claude-sonnet-4-6, claude-3-5-sonnet-20241022, claude-3-5-haiku-20241022
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-coder, deepseek-reasoner
# 智谱AI: glm-4-plus, glm-4, glm-4-air, glm-4-flash
# 月之暗面: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# Ollama: llama3.1, qwen2.5, deepseek-coder-v2 (需要本地运行 Ollama)
LLM_MODEL=deepseek-chat

# 通用 API Key (可选，优先级低于特定 provider 的 key)
LLM_API_KEY=your-llm-api-key

# 自定义 API 地址 (可选，用于 custom provider 或私有部署)
LLM_BASE_URL=

# 生成参数 (可选)
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ============================================
# Claude API (默认)
# ============================================
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# OpenAI API
# ============================================
# OPENAI_API_KEY=sk-your-openai-key

# ============================================
# DeepSeek API
# ============================================
# DEEPSEEK_API_KEY=sk-your-deepseek-key

# ============================================
# 智谱 AI API
# ============================================
# ZHIPU_API_KEY=your-zhipu-api-key

# ============================================
# 月之暗面 API
# ============================================
# MOONSHOT_API_KEY=sk-your-moonshot-key
# ============================================
# Web Search API (网络搜索，可选)
# ============================================
# 默认使用 DuckDuckGo (免费，无需配置，但在中国大陆可能无法访问)
# 
# 推荐方案（中国大陆用户）：
# 1. Bing Search API (有免费额度 1000次/月)
#    获取方式: https://portal.azure.com/ → 创建资源 → Bing Search v7
# 2. Tavily API (有免费额度 1000次/月)
#    获取方式: https://tavily.com/
#
# SEARCH_PROVIDER=duckduckgo
# BING_API_KEY=your-bing-api-key
# TAVILY_API_KEY=tvly-your-api-key


# ============================================
# Image Generation API (图片生成，可选)
# ============================================
# 支持多种图片生成服务:
# 1. SiliconFlow (推荐，有免费额度)
#    获取方式: https://cloud.siliconflow.cn/ → 账户设置 → API 密钥
# 2. 火山引擎方舟 (需要 API Key)
#    获取方式: https://console.volcengine.com/ark → API Key 管理
# 3. OpenAI DALL-E (需要 API Key)

# 选择图片生成提供商: volcano | siliconflow | openai | none
IMAGE_PROVIDER=siliconflow

# SiliconFlow API (推荐)
SILICONFLOW_API_KEY=your-siliconflow-api-key

# 火山引擎方舟 API
VOLCANO_API_KEY=your-volcano-ark-api-key
VOLCANO_MODEL=doubao-seedream-4-0-250828

# ============================================
# WeChat Official Account (微信公众号)
# ============================================
# Account 1 - Muggles School
WECHAT_APP_ID_MUGGLES=wx-your-app-id
WECHAT_APP_SECRET_MUGGLES=your-app-secret

# Account 2 - Add more accounts as needed
# WECHAT_APP_ID_ACCOUNT2=wx...
# WECHAT_APP_SECRET_ACCOUNT2=...

# ============================================
# Web App Authentication (Web 应用认证)
# ============================================
NEXTAUTH_SECRET=your-nextauth-secret-here
# ENCRYPTION_KEY is used to encrypt WeChat appSecret in the database
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=your-encryption-key-here
